{
  "name": "akira/laravel-pdf-invoices",
  "description": "A modern, strictly typed, and extensible invoice generator for Laravel 12+ built with PHP 8.4 syntax. This package provides a clean builder pattern API, immutable data objects, and modular design inspired by LaravelDaily/laravel-invoices but rewritten from scratch with SOLID principles and Laravel best practices.",
  "keywords": [
    "Akira",
    "laravel",
    "laravel-pdf-invoices",
    "pdf",
    "invoices",
    "invoice-generator",
    "billing",
    "billing-system",
    "billing-invoices",
    "pdf-invoices",
    "pdf-invoice-generator",
    "laravel-invoice-generator"
  ],
  "homepage": "https://github.com/akira-io/laravel-pdf-invoices",
  "license": "MIT",
  "authors": [
    {
      "name": "Kidiatoliny",
      "email": "kidiatoliny@akira-io.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "spatie/laravel-package-tools": "^1.93",
    "illuminate/contracts": "^12.0 | ^13.0  ",
    "spatie/browsershot": "^5.2.3",
    "spatie/laravel-pdf": "^2.2",
    "barryvdh/laravel-dompdf": "^2.0 || ^3.1.1"
  },
  "require-dev": {
    "akira/laravel-debugger": "^1.4",
    "larastan/larastan": "^3.9.2",
    "laravel/pint": "^1.27.1",
    "nunomaduro/collision": "^8.9.1",
    "orchestra/testbench": "^11.0.0||^10.9.0||^9.0.0",
    "pestphp/pest": "^4.4.1",
    "pestphp/pest-plugin-arch": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpstan/phpstan-phpunit": "^2.0.16",
    "rector/rector": "^2.3.8",
    "driftingly/rector-laravel": "^2.1.9",
    "peckphp/peck": "^0.2.0",
    "pestphp/pest-plugin-type-coverage": "^4.0.3"
  },
  "autoload": {
    "psr-4": {
      "Akira\\PdfInvoices\\": "src/",
      "Akira\\PdfInvoices\\Database\\Factories\\": "database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Akira\\PdfInvoices\\Tests\\": "tests/",
      "Workbench\\App\\": "workbench/app/"
    }
  },
  "scripts": {
    "post-autoload-dump": "@composer run prepare",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "lint": [
      "rector",
      "pint"
    ],
    "test:lint": "pint --test",
    "test:refactor": "rector --dry-run",
    "test:arch": "pest --filter=arch",
    "test:types": "phpstan",
    "test:type-coverage": "pest --type-coverage --min=100 --compact",
    "test:coverage": "pest --parallel --coverage --compact --exactly=100.0",
    "test:typos": "peck",
    "test": [
      "@test:lint",
      "@test:refactor",
      "@test:typos",
      "@test:arch",
      "@test:types",
      "@test:coverage",
      "@test:type-coverage"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Akira\\PdfInvoices\\PdfInvoicesServiceProvider"
      ],
      "aliases": {
        "PdfInvoices": "Akira\\PdfInvoices\\Facades\\PdfInvoices"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
