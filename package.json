{
  "name": "akira-laravel-pdf-invoices",
  "version": "0.1.0",
  "description": "A modern, strictly typed invoice generator for Laravel 12+",
  "private": true,
  "scripts": {
    "dev": "tailwindcss -i ./resources/css/app.css -o ./resources/css/compiled.css --watch",
    "build": "tailwindcss -i ./resources/css/app.css -o ./resources/css/compiled.css --minify",
    "test": "composer test",
    "lint": "composer format",
    "release": "release-it"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "tailwindcss": "^4.0.0",
    "release-it": "^17.0.0",
    "@release-it/conventional-changelog": "^7.0.0"
  },
  "release-it": {
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md"
      }
    },
    "git": {
      "commitMessage": "chore(release): v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    }
  }
}